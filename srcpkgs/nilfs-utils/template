maintainer="nox"
pkgname="nilfs-utils"
version=2.2.9pre
revision=1
_gitrev="67c8bc1fe6c8b7190b7bc68841bd2913b67bdd63"
short_desc="Log-structured file system for Linux - userspace utils"
makedepends+=" libblkid-devel"
makedepends+=" libmount-devel"
makedepends+=" libuuid-devel"
hostmakedepends+=" automake"
hostmakedepends+=" libtool"
homepage="https://nilfs.sourceforge.io/"
license="GPL-2.0-or-later, LGPL-2.1-or-later"
distfiles="https://github.com/nilfs-dev/nilfs-utils/archive/$_gitrev.tar.gz>$pkgname-$version.tar.gz"
checksum="3506c188768e710420f71d6c25daa26bf3d32d8cd97be64214199409d5657194"
wrksrc="$pkgname-$_gitrev"
conf_files="/etc/nilfs_cleanerd.conf"
patch_args="-Np1"
build_style="gnu-configure"
configure_args="--without-selinux"
make_install_args="sbindir=/usr/bin"

pre_configure() {
  autoreconf -fi
}

post_install() {
  mv "$DESTDIR/sbin"/* "$DESTDIR/usr/bin/"
}

libnilfs_package() {
  short_desc="Log-structured file system for Linux - userspace runtime libraries"
  pkg_install() {
    vmove "usr/lib/*.so.*"
  }
}

nilfs-utils-devel_package() {
  depends+=" $makedepends"
  depends+=" libnilfs>=${version}_$revision"
  short_desc="Log-structured file system for Linux - userspace development files"
  pkg_install() {
    vmove usr/include
    vmove "usr/lib/*.a"
    vmove "usr/lib/*.so"
  }
}

